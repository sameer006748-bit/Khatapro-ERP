// Accounting-First Garments ERP — Phase 1 schema
// All money values are stored as BigInt minor units (paisas) to satisfy
// the "integer minor units" rule and avoid floating-point drift.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =================== Identity & Access ===================
// We use NextAuth (credentials provider) backed by Prisma in place of
// Supabase Auth. The `User` table is the auth identity; `Profile` is the
// 1:1 business-side record that carries role + business linkage. There is
// no duplicated standalone `users` auth table.

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String?
  passwordHash      String
  // Phase 2.1: UUID from Supabase auth.users. Used as posted_by / user_id
  // for all Supabase writes (vouchers, audit_logs, etc.). Populated by
  // scripts/align-supabase-auth.ts. Nullable so the app still works if
  // Supabase Auth isn't configured yet.
  supabaseUserUuid  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  profile           Profile?

  @@index([supabaseUserUuid])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  roleId      String
  role        Role     @relation(fields: [roleId], references: [id])
  displayName String
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([roleId])
}

model Role {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  name        String
  isSystem    Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profiles    Profile[]
  permissions RolePermission[]

  @@unique([businessId, name])
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  module          String
  description     String?
  rolePermissions RolePermission[]

  @@index([module])
}

model RolePermission {
  id           String      @id @default(cuid())
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// =================== Business ===================

model Business {
  id         String   @id @default(cuid())
  name       String
  legalName  String?
  phone      String?
  address    String?
  currency   String   @default("PKR")
  timezone   String   @default("Asia/Karachi")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profiles         Profile[]
  roles            Role[]
  accountCategories AccountCategory[]
  accounts         Account[]
  businessAccounts BusinessAccount[]
  auditLogs        AuditLog[]
  vouchers         Voucher[]
  productCategories ProductCategory[]
  products         Product[]
  stockMovements   StockMovement[]
  salesmen         Salesman[]
  customers        Customer[]
  invoices         Invoice[]
  invoiceItems     InvoiceItem[]
  paymentAllocations PaymentAllocation[]
  salesmanCommissions SalesmanCommission[]
  salesReturns     SalesReturn[]
}

// =================== Chart of Accounts ===================

model AccountCategory {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  code       String
  name       String
  type       String

  accounts Account[]

  @@unique([businessId, code])
}

model Account {
  id                 String           @id @default(cuid())
  businessId         String
  business           Business         @relation(fields: [businessId], references: [id])
  code               String
  name               String
  categoryId         String
  category           AccountCategory  @relation(fields: [categoryId], references: [id])
  parentId           String?
  parent             Account?         @relation("AccountHierarchy", fields: [parentId], references: [id])
  children           Account[]        @relation("AccountHierarchy")
  isActive           Boolean          @default(true)
  isBusinessAccount  Boolean          @default(false)
  isPartyAccount     Boolean          @default(false)
  partyType          String?
  // Server-maintained cache in paisas; always derived from voucher lines.
  // In Phase 1 (no vouchers yet) it stays 0 for newly-created business accounts.
  balanceCache       BigInt           @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  businessAccount BusinessAccount?
  voucherLines    VoucherLine[]
  salesmen        Salesman[]
  customers       Customer[]
  paymentAllocations PaymentAllocation[]

  @@unique([businessId, code])
  @@index([categoryId])
  @@index([parentId])
  @@index([businessId, isBusinessAccount])
}

model BusinessAccount {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  accountId     String   @unique
  account       Account  @relation(fields: [accountId], references: [id])
  name          String
  type          String
  accountHolder String?
  bankName      String?
  accountNumber String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
  @@index([type])
}

// =================== Audit Log ===================

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  userId     String?
  action     String
  entity     String
  entityId   String?
  details    String?
  timestamp  DateTime @default(now())

  @@index([businessId, timestamp])
  @@index([entity, entityId])
}

// =================== Phase 2: Accounting Engine ===================

model Voucher {
  id              String         @id @default(cuid())
  businessId      String
  business        Business       @relation(fields: [businessId], references: [id])
  voucherNo       String?
  voucherType     String
  referenceId     String?
  referenceType   String?
  memo            String?
  voucherDate     DateTime
  postedAt        DateTime       @default(now())
  postedBy        String?
  isCancelled     Boolean        @default(false)
  cancelledAt     DateTime?
  cancelledBy     String?
  cancelVoucherId String?
  totalDebit      BigInt         @default(0)
  totalCredit     BigInt         @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  lines           VoucherLine[]

  @@index([businessId, voucherDate])
  @@index([businessId, voucherType])
  @@index([referenceType, referenceId])
}

model VoucherLine {
  id          String   @id @default(cuid())
  businessId  String
  voucherId   String
  voucher     Voucher  @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debit       BigInt   @default(0)
  credit      BigInt   @default(0)
  memo        String?
  lineOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([voucherId])
  @@index([businessId, accountId])
}

// =================== Phase 3: Products & Stock ===================

model ProductCategory {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]

  @@unique([businessId, name])
  @@index([businessId])
}

model Product {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id])
  name           String
  categoryId     String?
  category       ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit           String   @default("piece")
  salePrice      Float    @default(0)
  purchasePrice  Float    @default(0)
  currentStock   Int      @default(0)
  isTemporary    Boolean  @default(false)
  isActive       Boolean  @default(true)
  mergedIntoId   String?
  markedForMerge Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockMovements StockMovement[]
  invoiceItems   InvoiceItem[]

  @@index([businessId])
  @@index([businessId, categoryId])
  @@index([businessId, isTemporary])
  @@index([businessId, currentStock])
}

model StockMovement {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  movementType  String
  quantity      Int
  balanceAfter  Int
  reason        String?
  movementDate  DateTime @default(now())
  createdBy     String?
  createdAt     DateTime @default(now())
  voucherId     String?

  @@index([productId])
  @@index([businessId, movementDate])
  @@index([businessId, movementType])
}

// =================== Phase 4: Sales ===================

model Salesman {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  accountId     String   @unique
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  name          String
  phone         String?
  commissionPct Float    @default(5.0)
  isActive      Boolean  @default(true)
  userId        String?  // Links to Supabase auth.users UUID (via Prisma User.supabaseUserUuid)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices    Invoice[]
  commissions SalesmanCommission[]

  @@index([businessId])
  @@index([userId])
}

model Customer {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  accountId  String   @unique
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  name       String
  phone      String?
  address    String?
  city       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  invoices Invoice[]

  @@index([businessId])
}

model Invoice {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])
  invoiceNo       String
  invoiceType     String   // COUNTER | ONLINE | OFC
  invoiceDate     DateTime
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  salesmanId      String?
  salesman        Salesman? @relation(fields: [salesmanId], references: [id], onDelete: SetNull)
  customerName    String?
  customerPhone   String?
  customerAddress String?
  customerCity    String?
  subtotal        BigInt   @default(0)
  discount        BigInt   @default(0)
  total           BigInt   @default(0)
  paidAmount      BigInt   @default(0)
  voucherId       String?
  isCancelled     Boolean  @default(false)
  cancelledAt     DateTime?
  cancelVoucherId String?
  isReturned      Boolean  @default(false)
  returnVoucherId String?
  memo            String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items              InvoiceItem[]
  paymentAllocations PaymentAllocation[]
  commissions        SalesmanCommission[]
  salesReturns       SalesReturn[]

  @@unique([businessId, invoiceNo])
  @@index([businessId, invoiceDate])
  @@index([businessId, invoiceType])
  @@index([salesmanId])
  @@index([customerId])
}

model InvoiceItem {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName     String
  qty             Int
  unitPrice       BigInt
  lineTotal       BigInt
  isTemporary     Boolean  @default(false)
  stockMovementId String?
  createdAt       DateTime @default(now())

  @@index([invoiceId])
  @@index([productId])
}

model PaymentAllocation {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id])
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  amount         BigInt
  isChange       Boolean  @default(false)
  voucherId      String?
  allocationDate DateTime @default(now())
  createdBy      String?
  createdAt      DateTime @default(now())

  commissions SalesmanCommission[]

  @@index([invoiceId])
  @@index([accountId])
}

model SalesmanCommission {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id])
  salesmanId       String
  salesman         Salesman  @relation(fields: [salesmanId], references: [id], onDelete: Cascade)
  invoiceId        String
  invoice          Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  allocationId     String
  allocation       PaymentAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  collectedAmount  BigInt
  commissionPct    Float
  commissionAmount BigInt
  createdAt        DateTime @default(now())

  @@unique([allocationId, salesmanId])
  @@index([salesmanId])
  @@index([invoiceId])
}

model SalesReturn {
  id                 String   @id @default(cuid())
  businessId         String
  business           Business @relation(fields: [businessId], references: [id])
  originalInvoiceId  String
  originalInvoice    Invoice  @relation(fields: [originalInvoiceId], references: [id], onDelete: Restrict)
  returnVoucherId    String?
  returnDate         DateTime @default(now())
  total              BigInt
  reason             String?
  createdBy          String?
  createdAt          DateTime @default(now())

  @@index([originalInvoiceId])
}

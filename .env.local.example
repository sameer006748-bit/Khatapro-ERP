# KhataPro ERP — Supabase environment variables.
#
# Copy this file to `.env.local` and fill in real values from your Supabase
# project dashboard (Project Settings → API).
#
# The service-role key bypasses RLS — NEVER commit it, NEVER expose it to
# the browser. It is only ever read by server-side code (server-admin.ts,
# which imports 'server-only').

NEXT_PUBLIC_SUPABASE_URL=https://ebcebxwpddltiwrqybqc.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key-here>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-here>

# Legacy local-dev fallback (Prisma + NextAuth) — still used when Supabase
# env vars above are not set, so the app keeps running locally.
DATABASE_URL=file:/home/z/my-project/db/custom.db
NEXTAUTH_SECRET=DSdK/GQBJFOpMYvmR3yX6C4xr1vwLNsYRnMydNhQu5Q=
NEXTAUTH_URL=http://localhost:3000
